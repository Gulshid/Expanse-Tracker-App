<?xml version="1.0" encoding="utf-8"?>
<!--
  item_category_row.xml — Category breakdown row
  Design: Colored dot + name, amount, percent, and tinted progress bar.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_md">

    <!-- Color dot -->
    <View
        android:id="@+id/viewDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_category_dot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressCategory" />

    <!-- Category name -->
    <TextView
        android:id="@+id/tvCategoryName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="@color/text_primary"
        app:layout_constraintStart_toEndOf="@id/viewDot"
        app:layout_constraintEnd_toStartOf="@id/tvCategoryAmount"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressCategory" />

    <!-- Amount -->
    <TextView
        android:id="@+id/tvCategoryAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvCategoryPercent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressCategory" />

    <!-- Percent badge -->
    <TextView
        android:id="@+id/tvCategoryPercent"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressCategory" />

    <!-- Progress bar (tinted per category in code) -->
    <ProgressBar
        android:id="@+id/progressCategory"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:layout_marginTop="@dimen/spacing_xs"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/gold"
        android:progressBackgroundTint="@color/card_stroke"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCategoryName" />

</androidx.constraintlayout.widget.ConstraintLayout>
